{
  "name": "poketernity",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "start:dev": "vite --mode development",
    "build": "vite build",
    "build:beta": "vite build --mode beta",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "test": "vitest run --no-isolate",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "test:silent": "vitest run --silent='passed-only' --no-isolate",
    "test:full": "tsc --noEmit && vitest run --silent='passed-only' --no-isolate",
    "test:create": "node scripts/create-test/create-test.js",
    "typecheck": "tsc --noEmit",
    "eslint": "eslint --fix .",
    "eslint-ci": "eslint .",
    "biome": "biome check --write --changed --no-errors-on-unmatched",
    "biome:unsafe": "biome check --write --unsafe --changed --no-errors-on-unmatched",
    "biome-ci": "biome ci --diagnostic-level=error --reporter=github --no-errors-on-unmatched",
    "biome-all": "biome check --write --no-errors-on-unmatched",
    "biome-all:unsafe": "biome check --write --unsafe --no-errors-on-unmatched",
    "docs": "typedoc",
    "depcruise": "depcruise src test",
    "postinstall": "lefthook install; git submodule update --init --recursive",
    "update-version:patch": "pnpm version patch --force --no-git-tag-version",
    "update-version:minor": "pnpm version minor --force --no-git-tag-version",
    "update-locales:remote": "git submodule update --progress --init --recursive --force --remote"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@types/crypto-js": "^4.2.2",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.0",
    "@vitest/coverage-istanbul": "^4.0.7",
    "@vitest/expect": "^4.0.7",
    "chalk": "^5.6.2",
    "dependency-cruiser": "^17.2.0",
    "inquirer": "^12.10.0",
    "jsdom": "^27.1.0",
    "lefthook": "^2.0.2",
    "msw": "^2.12.0",
    "phaser3spectorjs": "^0.0.8",
    "typedoc": "^0.28.14",
    "typescript": "^5.9.3",
    "vite": "^7.2.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.7",
    "vitest-canvas-mock": "^0.3.3"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.3.0",
    "ajv": "^8.17.1",
    "compare-versions": "^6.1.1",
    "crypto-js": "^4.2.0",
    "i18next": "^25.6.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "i18next-korean-postposition-processor": "^1.0.0",
    "jszip": "^3.10.1",
    "phaser": "^3.90.0",
    "phaser3-rex-plugins": "^1.80.17"
  },
  "engines": {
    "node": ">=24.9.0"
  },
  "optionalDependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1"
  }
}
