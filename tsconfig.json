{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noImplicitOverride": true,
    "sourceMap": false,
    // #region `strict` options
    "strict": false,
    "alwaysStrict": true,
    "strictBindCallApply": true,
    "strictBuiltinIteratorReturn": true,
    "strictFunctionTypes": false, // TODO: refactor so this can be true
    "strictNullChecks": true,
    "strictPropertyInitialization": false, // TODO: refactor so this can be true
    "noImplicitAny": false, // TODO: refactor so this can be true
    "noImplicitThis": true,
    "useUnknownInCatchVariables": false, // TODO: refactor so this can be true
    // #endregion
    "rootDir": ".",
    "baseUrl": "./src",
    "paths": {
      "#enums/*": ["./enums/*.ts"],
      "#app/*": ["./*.ts"],
      "#test/*": ["../test/*.ts"]
    },
    "outDir": "./build",
    "noEmit": true
  },
  "typedocOptions": {
    "entryPoints": ["./src"],
    "entryPointStrategy": "expand",
    "exclude": "**/*+.test.ts",
    "out": "typedoc"
  },
  "exclude": ["node_modules", "dist", "vite.config.ts", "vitest.config.ts", "vitest.workspace.ts"]
}
